# LLM 심층 분석용 환경변수 템플릿.
# 실제 값을 채워 .env 로 복사하세요 (cp .env.example .env). .env 는 git에 커밋되지 않습니다.

# 방법 A) OpenRouter (권장 — OpenAI 호환)
OPENROUTER_API_KEY=sk-or-v1-...
DC_LLM_MODEL=anthropic/claude-sonnet-5   # 저비용: anthropic/claude-haiku-4.5

# 방법 B) Anthropic 직접 (위 대신 이걸 사용)
# ANTHROPIC_API_KEY=sk-ant-...
# DC_LLM_MODEL=claude-sonnet-5
